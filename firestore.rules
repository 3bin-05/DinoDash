rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. User Profiles Collection
    match /users/{uid} {
      allow read: if request.auth != null;

      // Create: user owns document, profile is valid, timestamps are valid, and they own the username registry doc
      allow create: if request.auth != null 
        && request.auth.uid == uid
        && isValidUserProfile(request.resource.data)
        && validateTimestamps()
        && getAfter(/databases/$(database)/documents/usernames/$(request.resource.data.username)).data.uid == uid;

      // Update: user owns document, profile is valid, they own the username registry (if changed), 
      // and they are not cheating (score increases by <= 15000, games counter increments correctly)
      allow update: if request.auth != null 
        && request.auth.uid == uid
        && isValidUserProfile(request.resource.data)
        && (request.resource.data.username == resource.data.username 
            || getAfter(/databases/$(database)/documents/usernames/$(request.resource.data.username)).data.uid == uid)
        && (request.resource.data.bestScore <= resource.data.bestScore || request.resource.data.bestScore - resource.data.bestScore <= 15000)
        && (request.resource.data.totalGames == resource.data.totalGames || request.resource.data.totalGames == resource.data.totalGames + 1)
        && (request.resource.data.totalDistance >= resource.data.totalDistance);
    }

    // 2. Username Registry Collection (Enforces database-level uniqueness)
    match /usernames/{username} {
      allow read: if request.auth != null;
      
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && username.matches('^[a-zA-Z0-9_]+$')
        && username.size() >= 3 
        && username.size() <= 20;

      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // 3. Dynamic Leaderboard Collections (Wildcard matching for daily/weekly/all-time)
    match /{leaderboardColl}/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.uid == uid
        && (leaderboardColl.startsWith("leaderboard_today_") || leaderboardColl.startsWith("leaderboard_weekly_"))
        && isValidLeaderboardEntry(request.resource.data)
        // Anti-Cheat: Leaderboard score must not exceed the verified bestScore in the user's profile
        && (!exists(/databases/$(database)/documents/users/$(uid)) || request.resource.data.score <= get(/databases/$(database)/documents/users/$(uid)).data.bestScore);
    }

    // Helper: Validates user profile data schema and constraints
    function isValidUserProfile(data) {
      return data.username is string
        && data.username.size() >= 3 
        && data.username.size() <= 20
        && data.username.matches('^[a-zA-Z0-9_]+$')
        && (data.bestScore is int && data.bestScore >= 0 && data.bestScore < 500000)
        && (data.totalGames is int && data.totalGames >= 0)
        && (data.totalDistance is int && data.totalDistance >= 0)
        && data.selectedSkin is string
        && data.achievements is list
        && data.unlockedSkins is list;
    }

    // Helper: Prevents tampering with the creation timestamp
    function validateTimestamps() {
      return request.method == 'create' 
        ? request.resource.data.createdAt == request.time
        : request.resource.data.createdAt == resource.data.createdAt;
    }

    // Helper: Validates dynamic leaderboard entry formatting
    function isValidLeaderboardEntry(data) {
      return data.uid == request.auth.uid
        && data.username is string
        && data.score is int 
        && data.score >= 0 
        && data.score < 500000
        && data.timestamp is timestamp;
    }
  }
}
